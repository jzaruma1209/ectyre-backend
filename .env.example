# ═══════════════════════════════════════════════════════
#  ECTYRE API — Variables de Entorno
#  Copiar este archivo a .env y completar los valores
#  cp .env.example .env
# ═══════════════════════════════════════════════════════

# ─── Servidor ───────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=8080

# ─── Base de Datos PostgreSQL ────────────────────────────
# Formato: postgres://USUARIO:PASSWORD@HOST:PUERTO/BASE_DE_DATOS
DATABASE_URL=postgres://postgres:root@localhost:5433/ectyre_db
DATABASE_URL_TEST=postgres://postgres:root@localhost:5433/ectyre_db_test

# ─── Autenticación JWT ───────────────────────────────────
# Mínimo 64 caracteres aleatorios. Generar con:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
TOKEN_SECRET=CAMBIAR_POR_UN_SECRETO_DE_AL_MENOS_64_CARACTERES_ALEATORIOS_AQUI

# ─── CORS — Orígenes permitidos (solo producción) ────────
# Lista separada por comas de dominios autorizados.
# En desarrollo (*) se acepta todo; en producción SOLO los listados aquí.
# Ejemplo múltiples orígenes: https://ectyre.com,https://admin.ectyre.com
CORS_ORIGIN=https://ectyre.com

# ─── Rate Limiting ───────────────────────────────────────
# RATE_LIMIT_WINDOW_MS  → ventana de tiempo en milisegundos (default: 900000 = 15 min)
# RATE_LIMIT_MAX        → máximo de peticiones por IP en esa ventana (default: 100)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
