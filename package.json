{
  "name": "llantas247-api",
  "version": "1.0.0",
  "description": "API REST para e-commerce de llantas Llantas247 usando Node.js, Express, Sequelize y PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "reset:migrate": "node src/tests/testMigrate.js",
    "pretest": "npm run reset:migrate",
    "db:create": "npx sequelize-cli db:create",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:seed": "npx sequelize-cli db:seed:all"
  },
  "keywords": [
    "llantas",
    "e-commerce",
    "rest-api",
    "nodejs",
    "express",
    "sequelize",
    "postgresql"
  ],
  "author": "Llantas247 Team",
  "license": "ISC",
  "dependencies": {
    "express": "^4.21.2",
    "sequelize": "6.37.3",
    "pg": "8.13.0",
    "pg-hstore": "2.3.4",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "16.4.5",
    "cors": "2.8.5",
    "helmet": "8.0.0",
    "express-rate-limit": "^7.1.0",
    "express-validator": "^7.0.0"
  },
  "devDependencies": {
    "nodemon": "3.1.7",
    "jest": "^30.0.0",
    "supertest": "^7.0.0"
  },
  "type": "commonjs"
}
