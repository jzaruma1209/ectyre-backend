{
  "info": {
    "_postman_id": "ectyre-api-v1-local-collection",
    "name": "🛞 Ectyre API v1.0",
    "description": "Colección completa API Ectyre — 36 endpoints en 8 módulos.\n\n**Antes de usar:** Selecciona el environment 'Ectyre API - Local' en Postman.\n\n**Flujo recomendado:**\n1. Ejecuta 'Login' → el token se guarda automáticamente en {{token}}\n2. Para rutas Admin, haz login con admin@ectyre.com y guarda en {{adminToken}}\n3. Cambia la URL en el environment si usas producción.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1",
      "description": "URL base de la API. Cambiar aquí o en el environment."
    }
  ],
  "item": [
    {
      "name": "🏥 Health Check",
      "item": [
        {
          "name": "Bienvenida [Pública]",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": [""]
            },
            "description": "🌍 Público — Muestra bienvenida y lista de módulos disponibles."
          }
        },
        {
          "name": "Health Check [Pública]",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["health"]
            },
            "description": "🌍 Público — Estado del servidor: { success, status, timestamp }"
          }
        }
      ]
    },
    {
      "name": "👤 Clientes",
      "item": [
        {
          "name": "Registro [Pública]",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipoIdentificacion\": \"CEDULA\",\n  \"numeroIdentificacion\": \"0959401332\",\n  \"nombres\": \"Paul\",\n  \"apellidos\": \"Zaruma\",\n  \"email\": \"zpaul3984@gmail.com\",\n  \"telefono\": \"0991234567\",\n  \"password\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/clientes/registro",
            "description": "🌍 Público — Registrar nuevo cliente. Campos: tipoIdentificacion (CEDULA|RUC|PASAPORTE), numeroIdentificacion, nombres, apellidos, email, telefono, password. Rate limit: 3/hora por IP."
          }
        },
        {
          "name": "Login Usuario [Pública]",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.environment.set('token', res.data.token);",
                  "  console.log('✅ Token guardado en {{token}}');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"carlos.mendoza@test.com\",\n  \"password\": \"Test1234!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/clientes/login",
            "description": "🌍 Público — Login usuario normal (Carlos). El test script guarda el token automáticamente en {{token}}. Rate limit: 5/15min."
          }
        },
        {
          "name": "Login Admin [Pública]",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.environment.set('adminToken', res.data.token);",
                  "  console.log('✅ Admin Token guardado en {{adminToken}}');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@ectyre.com\",\n  \"password\": \"Admin2026#Ectyre\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/clientes/login",
            "description": "🌍 Público — Login admin. El test script guarda el token automáticamente en {{adminToken}}."
          }
        },
        {
          "name": "Logout [Privada]",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/clientes/logout",
            "description": "🔒 JWT — Cerrar sesión."
          }
        },
        {
          "name": "Ver Perfil [Privada]",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/clientes/perfil",
            "description": "🔒 JWT — Perfil del cliente autenticado."
          }
        },
        {
          "name": "Actualizar Perfil [Privada]",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombres\": \"Carlos Actualizado\",\n  \"telefono\": \"0997654321\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/clientes/perfil",
            "description": "🔒 JWT — Actualizar nombres y teléfono."
          }
        }
      ]
