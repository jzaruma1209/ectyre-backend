{
  "name": "apiectyre",
  "version": "1.0.0",
  "description": "API REST para el ecosistema Ectyre (E-commerce y Servicios) usando Node.js, Express, Sequelize y PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "reset:migrate": "node src/tests/testMigrate.js",
    "pretest": "npm run reset:migrate",
    "db:create": "npx sequelize-cli db:create",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:migrate:prod": "NODE_ENV=production npx sequelize-cli db:migrate",
    "db:seed:prod": "NODE_ENV=production npx sequelize-cli db:seed:all",
    "prestart": "node -e \"if(!process.env.VERCEL) require('child_process').execSync('npx sequelize-cli db:migrate', {stdio:'inherit'});\""
  },
  "engines": {
    "node": ">=20.x"
  },
  "keywords": [
    "llantas",
    "e-commerce",
    "rest-api",
    "nodejs",
    "express",
    "sequelize",
    "postgresql"
  ],
  "author": "Ectyre Team",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.0",
    "express-session": "^1.19.0",
    "express-validator": "^7.0.0",
    "helmet": "8.0.0",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "8.13.0",
    "pg-hstore": "2.3.4",
    "sequelize": "6.37.3"
  },
  "devDependencies": {
    "jest": "^30.0.0",
    "nodemon": "3.1.7",
    "supertest": "^7.0.0"
  },
  "type": "commonjs"
}
