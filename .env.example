# ═══════════════════════════════════════════════════════
#  LLANTAS247 API — Variables de Entorno
#  Copiar este archivo a .env y completar los valores
#  cp .env.example .env
# ═══════════════════════════════════════════════════════

# ─── Servidor ───────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=8080

# ─── Base de Datos PostgreSQL ────────────────────────────
# Formato: postgres://USUARIO:PASSWORD@HOST:PUERTO/BASE_DE_DATOS
DATABASE_URL=postgres://postgres:root@localhost:5432/llantas247_db

# ─── Autenticación JWT ───────────────────────────────────
# Mínimo 64 caracteres aleatorios. Generar con:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
TOKEN_SECRET=CAMBIAR_POR_UN_SECRETO_DE_AL_MENOS_64_CARACTERES_ALEATORIOS_AQUI

# ─── CORS (solo en producción) ───────────────────────────
# URL del frontend que puede acceder a la API
# En desarrollo se acepta cualquier origen (*).
CORS_ORIGIN=https://llantas247.com

# ─── Configuración opcional ──────────────────────────────
# Límites de rate limiting (en ms y número de requests)
RATE_LIMIT_WINDOW_MS=900000   # 15 minutos
RATE_LIMIT_MAX=100            # máx requests por ventana
